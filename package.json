{
  "name": "spotter-app",
  "version": "1.0.0",
  "description": "Standalone Mac app embedding ThoughtSpot Spotter",
  "main": "src/main/main.js",
  "scripts": {
    "start": "webpack --mode development && electron .",
    "dev": "webpack --mode development --watch & electron .",
    "build": "webpack --mode production",
    "pack": "webpack --mode production && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.thoughtspot.spotter",
    "productName": "Spotter",
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "identity": null
    },
    "afterPack": "./scripts/afterPack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "build/**/*"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.10.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@thoughtspot/visual-embed-sdk": "^1.46.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
