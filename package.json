{
  "name": "spotter-app",
  "version": "1.2.0",
  "description": "Standalone Mac app embedding ThoughtSpot Spotter",
  "main": "src/main/main.js",
  "scripts": {
    "start": "webpack --mode development && electron .",
    "dev": "webpack --mode development --watch & electron .",
    "build": "webpack --mode production",
    "pack": "webpack --mode production && electron-builder --mac --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.thoughtspot.spotter",
    "productName": "Spotter",
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": false
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "build/**/*"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.0",
    "@electron/notarize": "^3.1.1",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.10.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@fontsource/lexend": "^5.2.11",
    "@thoughtspot/visual-embed-sdk": "^1.46.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
